{
  "$schema": "https://raw.githubusercontent.com/nicholasrice/tauri/v2/crates/tauri-utils/schema.json",
  "identifier": "default",
  "description": "Default capability with minimal permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:webview:allow-set-webview-zoom",
    "shell:allow-open",
    "dialog:allow-open",
    "fs:allow-read"
  ]
}
